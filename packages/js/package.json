{
  "name": "@jitforms/js",
  "version": "0.1.0",
  "description": "Core JavaScript/TypeScript SDK for JitForms — form submission with honeypot, captcha, typed errors. Zero dependencies.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "keywords": ["jitforms", "forms", "sdk", "form-handling", "typescript"],
  "author": "El Mehdi El fatihi <tech@jitforms.com>",
  "license": "MIT",
  "homepage": "https://github.com/jitforms/jitforms-integrations#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jitforms/jitforms-integrations.git",
    "directory": "packages/js"
  },
  "bugs": "https://github.com/jitforms/jitforms-integrations/issues",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
