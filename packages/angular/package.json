{
  "name": "@jitforms/angular",
  "version": "0.1.0",
  "description": "Angular service for JitForms with RxJS observable state. Auto-zone-aware.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@jitforms/js": "^0.1.0"
  },
  "peerDependencies": {
    "@angular/core": ">=17.0.0",
    "rxjs": ">=7.0.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  },
  "keywords": ["jitforms", "angular", "forms", "service", "rxjs", "form-handling"],
  "author": "El Mehdi El fatihi <tech@jitforms.com>",
  "license": "MIT",
  "homepage": "https://github.com/jitforms/jitforms-integrations#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jitforms/jitforms-integrations.git",
    "directory": "packages/angular"
  },
  "bugs": "https://github.com/jitforms/jitforms-integrations/issues",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
