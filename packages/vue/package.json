{
  "name": "@jitforms/vue",
  "version": "0.1.0",
  "description": "Vue 3 composable (useJitForm) for JitForms — reactive form state and validation.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@jitforms/js": "^0.1.0"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  },
  "keywords": ["jitforms", "vue", "vue3", "composable", "forms", "form-handling"],
  "author": "El Mehdi El fatihi <tech@jitforms.com>",
  "license": "MIT",
  "homepage": "https://github.com/jitforms/jitforms-integrations#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jitforms/jitforms-integrations.git",
    "directory": "packages/vue"
  },
  "bugs": "https://github.com/jitforms/jitforms-integrations/issues",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
