{
  "name": "@jitforms/next",
  "version": "0.1.0",
  "description": "Next.js hook and server actions for JitForms — formAction + CORS-free server submit.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@jitforms/js": "^0.1.0",
    "@jitforms/react": "^0.1.0"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  },
  "keywords": ["jitforms", "nextjs", "next", "server-actions", "forms", "form-handling"],
  "author": "El Mehdi El fatihi <tech@jitforms.com>",
  "license": "MIT",
  "homepage": "https://github.com/jitforms/jitforms-integrations#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jitforms/jitforms-integrations.git",
    "directory": "packages/next"
  },
  "bugs": "https://github.com/jitforms/jitforms-integrations/issues",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
