---
import JitForm from '@jitforms/astro/JitForm.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>JitForms — Astro Example</title>
    <style>
      :root { font-family: ui-sans-serif, system-ui, sans-serif; color-scheme: light dark; }
      body { max-width: 480px; margin: 3rem auto; padding: 0 1.5rem; }
      h1 { font-size: 1.5rem; margin: 0 0 0.5rem; }
      .sub { color: #888; margin: 0 0 2rem; font-size: 0.9rem; }
      form { display: flex; flex-direction: column; gap: 1rem; }
      label { display: block; font-size: 0.85rem; margin-bottom: 0.25rem; color: #555; }
      input, textarea { width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #ccc; border-radius: 6px; font-size: 0.95rem; font-family: inherit; box-sizing: border-box; }
      textarea { min-height: 5rem; resize: vertical; }
      button { padding: 0.6rem 1rem; background: #111; color: white; border: none; border-radius: 6px; font-size: 0.95rem; cursor: pointer; }
      .error { color: #c00; font-size: 0.8rem; margin-top: 0.25rem; }
      [data-jitform-success] { padding: 1rem; background: #e6f4ea; color: #1b5e20; border-radius: 6px; display: none; }
      [data-jitform-error] { color: #c00; font-size: 0.8rem; margin-top: 0.25rem; }
      :global(form.jf-success) [data-jitform-success] { display: block !important; }
      :global(form.jf-success) > div:not(:last-child),
      :global(form.jf-success) button { display: none; }
      @media (prefers-color-scheme: dark) {
        body { background: #111; color: #eee; }
        input, textarea { background: #222; color: #eee; border-color: #444; }
        .sub { color: #aaa; } label { color: #bbb; }
        [data-jitform-success] { background: #1b5e20; color: #e6f4ea; }
      }
    </style>
  </head>
  <body>
    <h1>Astro — @jitforms/astro</h1>
    <p class="sub">Drop-in <code>&lt;JitForm&gt;</code> component on <code>jitforms.test</code>.</p>

    <JitForm formHash="Jve1ZElW" baseUrl="https://jitforms.test" honeypot>
      <div>
        <label for="name">Name</label>
        <input id="name" name="name" />
        <div data-jitform-error="name"></div>
      </div>
      <div>
        <label for="email">Email</label>
        <input id="email" name="email" type="email" />
        <div data-jitform-error="email"></div>
      </div>
      <div>
        <label for="message">Message</label>
        <textarea id="message" name="message"></textarea>
        <div data-jitform-error="message"></div>
      </div>
      <button type="submit">Send</button>
      <div data-jitform-success>✓ Submitted successfully.</div>
    </JitForm>
  </body>
</html>
