{
  "name": "jitforms-integrations",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/js && npm run build -w packages/html -w packages/react -w packages/vue -w packages/angular -w packages/svelte -w packages/astro && npm run build -w packages/next",
    "clean": "rm -rf packages/*/dist",
    "lint": "eslint packages/*/src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/vue": "^8.1.0",
    "@types/react": "^19.0.0",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
